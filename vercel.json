{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.eliteparfumscr.com"
        }
      ],
      "destination": "https://elite-costarica.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "eliteparfumscr.com"
        }
      ],
      "destination": "https://elite-costarica.com/:path*",
      "permanent": true
    },
    {
      "source": "/catalogo.html",
      "destination": "/catalogo",
      "permanent": true
    },
    {
      "source": "/oro.html",
      "destination": "/oro",
      "permanent": true
    },
    {
      "source": "/testimonios.html",
      "destination": "/testimonios",
      "permanent": true
    },
    {
      "source": "/pieza.html",
      "destination": "/pieza",
      "permanent": true
    }
  ]
}
